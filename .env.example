# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# LLM model to use (gpt-4o-mini is cheaper; gpt-4o is more accurate)
OPENAI_MODEL=gpt-4o-mini

# ── Optional: AWS (app runs locally without these) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET_NAME=healthcare-claims-bucket

# ── Local paths (defaults work out of the box) ────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
POLICY_DOCS_DIR=./data/policy_documents
CLAIMS_DIR=./data/synthetic_claims
OUTPUT_DIR=./data/outputs
